          "expr": "sum(increase(ai_tokens_total{appId=~\"$appId\", userId=~\"$userId\", modelName=~\"$modelName\"}[$__range])) by (tokenType)",
          "legendFormat": "{{tokenType}}",
          "refId": "A"
