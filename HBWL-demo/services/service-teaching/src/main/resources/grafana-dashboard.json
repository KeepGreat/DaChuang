      "targets": [
        {
          "expr": "sum(rate(ai_tokens_total{appId=~\"$appId\", userId=~\"$userId\", modelName=~\"$modelName\"}[5m])) by (tokenType)",
          "legendFormat": "{{tokenType}}",
